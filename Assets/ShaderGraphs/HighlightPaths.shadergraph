        },
        {
            "m_Id": "af700bfac7d64ca097a104b446a7e416"
        },
        {
            "m_Id": "4390e281c7ab453c9eaaca8453fa0a7e"
        },
        {
            "m_Id": "c2effade22e64af9afce47e3c7345abb"
        },
        {
            "m_Id": "f81c17c578b94a338ca29ed559ea0e07"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 3,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 2,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "BitMap_Separater",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "int m = (int)Mask;\n\nBit0 = (m & 1) ? 1.0 : 0.0;\nBit1 = (m & 2) ? 1.0 : 0.0;\nBit2 = (m & 4) ? 1.0 : 0.0;\nBit3 = (m & 8) ? 1.0 : 0.0;\nBit4 = (m & 16) ? 1.0 : 0.0;\nBit5 = (m & 32) ? 1.0 : 0.0;"
}

