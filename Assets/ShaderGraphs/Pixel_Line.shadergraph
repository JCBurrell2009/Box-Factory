            "m_Id": "54d0c62d13b54d82a2aa04a6c89a0acb"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 1,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "SDF_Line",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float2 pa = p - a, ba = b - a;\nfloat h = clamp(dot(pa, ba) / dot(ba, ba), 0.0, 1.0);\ndist = length(pa - ba * h);"
}

